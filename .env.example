# Environment Configuration
# Copy to .env and fill in your API keys

# Polygon RPC - Get free key at https://www.alchemy.com/
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/your_key_here

# Dune Analytics - Get free key at https://dune.com/settings/api
DUNE_API_KEY=your_dune_key_here

# Goldsky - Get free tier at https://goldsky.com/
GOLDSKY_API_KEY=your_goldsky_key_here

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=polymarket
POSTGRES_PASSWORD=polymarket_secret
POSTGRES_DB=polymarket_detector

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Target Market
TARGET_MARKET=israel-strike-iran-nuclear-facility-before-july
